# CityStage backend configuration
#
# The DEEPSEEK_API_KEY is the ONLY sensitive value in this file.
# It is read server-side only (server/index.ts) and is never
# bundled into the client JavaScript or sent to the browser.
#
# To get a key: https://platform.deepseek.com/
#
# Copy this file to `.env` and fill in your real key:
#   cp .env.example .env

# DeepSeek API key (server-side only — never sent to the client)
DEEPSEEK_API_KEY=

# Optional overrides (defaults shown)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# PORT=3001
